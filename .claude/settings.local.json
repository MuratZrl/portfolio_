      "Bash(curl -s -o /dev/null -w \"optimized pulsechat: %{http_code} \\(%{size_download}b, %{content_type}\\)\\\\n\" \"http://localhost:3000/_next/image?url=%2Fimages%2Fprojects%2Fpulsechat.png&w=3840&q=75\")",
