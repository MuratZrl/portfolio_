      "Bash(curl -s -o /dev/null -w \"teamboard detail: %{http_code}\\\\n\" http://localhost:3000/projects/teamboard)",
      "Bash(curl -s -o /dev/null -w \"pulsechat detail: %{http_code}\\\\n\" http://localhost:3000/projects/pulsechat)",
      "Bash(curl -s -o /dev/null -w \"yenigunemlak detail: %{http_code}\\\\n\" http://localhost:3000/projects/yenigunemlak)",
      "Bash(curl -s -o /dev/null -w \"teamboard.png: %{http_code} \\(%{size_download} bytes\\)\\\\n\" http://localhost:3000/images/projects/teamboard.png)",
      "Bash(curl -s http://localhost:3000/)",
